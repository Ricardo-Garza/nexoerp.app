# ============================================================
# Nexo ERP — variables de entorno (nombres; nunca commitear valores)
# ============================================================

# --- Firebase (módulos legacy: auth, CRM, ventas, bancos, etc.) ---
# Requeridas en producción/preview. Sin ellas la app entra en modo demo.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- White-label (opcionales; defaults: Nexo ERP / tenant DELAR Foods) ---
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_SHORT_NAME=
NEXT_PUBLIC_APP_TAGLINE=

# --- Modo de autenticación ---
# "demo" SOLO para desarrollo local/CI/E2E. JAMÁS en producción.
# NEXT_PUBLIC_AUTH_MODE=demo

# --- CRM Momentum (server-side; sandbox si está vacía) ---
# MOMENTUM_BASE_URL=https://crm-staging.example.com
